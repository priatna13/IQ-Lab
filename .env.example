# Public (browser-safe). From InsForge project: oss_host + ANON_KEY.
NEXT_PUBLIC_INSFORGE_URL=https://your-appkey.region.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=anon_...
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only (never NEXT_PUBLIC_*). From CLI secrets / .insforge/project.json api_key.
INSFORGE_URL=https://your-appkey.region.insforge.app
INSFORGE_API_KEY=ik_...

# --- Soft-launch ops (see docs/SOFT-LAUNCH-OPS.md) ---
# Optional: OpenRouter for Insight LLM (template fallback if unset). ADR 0016.
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#
# Google OAuth: enable provider in InsForge Dashboard (not an env var in this app).
# Email verification / SMTP: insforge.toml [auth] + [auth.smtp]

# Optional product analytics (C2) — no PII in events
# POSTHOG_KEY=phc_...
# POSTHOG_HOST=https://us.i.posthog.com
# ANALYTICS_WEBHOOK_URL=https://example.com/hooks/iq-lab

